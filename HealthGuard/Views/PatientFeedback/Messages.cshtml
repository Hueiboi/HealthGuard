@model List<HealthGuard.Models.Dto.FeedbackResponseDto>
@{
    ViewData["Title"] = "Tin nhắn & Phản hồi";
}

<div class="container py-5" style="max-width: 900px;">
    <div class="d-flex align-items-center mb-4">
        <div style="width: 50px; height: 50px; background: #e2eafc; color: #2563eb; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
            <i class="bi bi-chat-dots-fill fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0">Tin nhắn của bạn</h2>
            <p class="text-muted mb-0">Lưu trữ các phản hồi và đánh giá sau mỗi phiên chẩn đoán.</p>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-chat-left-quote text-light" style="font-size: 4rem;"></i>
            <p class="mt-3 text-muted">Bạn chưa có tin nhắn hoặc phản hồi nào.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var fb in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-4 transition-hover">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-light text-primary rounded-pill px-3 py-2">
                                <i class="bi bi-hash me-1"></i> Phiên khám #@fb.SessionId
                            </span>
                            <small class="text-muted">@fb.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</small>
                        </div>
                        <p class="text-dark mb-0" style="line-height: 1.6; font-size: 1.05rem;">
                            @fb.Comments
                        </p>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .fw-800 {
        font-weight: 800;
    }

    .transition-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        transition: 0.3s;
    }
</style>