@{
    Layout = null;
    ViewData["Title"] = "Đăng ký tài khoản - Patient Portal";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* GIỮ NGUYÊN TOÀN BỘ CSS CỦA ÔNG */
        body {
            background-color: #f8fafc;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            padding: 40px 20px;
        }

        .register-container {
            max-width: 1000px;
            width: 100%;
            margin: auto;
            background: white;
            border-radius: 30px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.03);
        }

        .info-panel {
            flex: 1;
            background: linear-gradient(135deg, #f0f4ff 0%, #e2eafc 100%);
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand {
            font-size: 1.25rem;
            font-weight: 800;
            color: #0d47a1;
            margin-bottom: 50px;
        }

        .headline {
            font-size: 2.8rem;
            font-weight: 800;
            color: #1e293b;
            line-height: 1.2;
            margin-bottom: 20px;
        }

            .headline span {
                color: #0d47a1;
            }

        .sub-headline {
            color: #475569;
            font-size: 1.05rem;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .badge-secure {
            background: white;
            padding: 15px 20px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            width: fit-content;
        }

        .badge-icon {
            width: 40px;
            height: 40px;
            background: #eff6ff;
            color: #0d47a1;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .badge-text strong {
            display: block;
            color: #1e293b;
            font-size: 0.9rem;
        }

        .badge-text span {
            color: #64748b;
            font-size: 0.8rem;
        }

        .form-panel {
            flex: 1.2;
            padding: 50px 60px;
        }

        .form-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 10px;
        }

        .form-subtitle {
            color: #64748b;
            margin-bottom: 30px;
            font-size: 0.95rem;
        }

        .input-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #475569;
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 0.5px;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 20px;
        }

            .input-group-custom i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: #64748b;
                font-size: 1.1rem;
            }

        .form-control-custom {
            width: 100%;
            background: #f1f5f9;
            border: 1px solid transparent;
            border-radius: 16px;
            padding: 14px 16px 14px 45px;
            font-size: 0.95rem;
            color: #334155;
            transition: 0.2s;
            outline: none;
        }

            .form-control-custom:focus {
                background: white;
                border-color: #0d47a1;
                box-shadow: 0 0 0 4px rgba(13, 71, 161, 0.1);
            }

        .btn-primary-custom {
            background: #0d47a1;
            color: white;
            border: none;
            width: 100%;
            padding: 14px;
            border-radius: 16px;
            font-weight: 600;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            transition: 0.2s;
            margin-top: 10px;
            cursor: pointer;
        }

            .btn-primary-custom:hover {
                background: #155eef;
            }

        .login-link {
            text-align: center;
            margin-top: 25px;
            font-size: 0.9rem;
            color: #64748b;
        }

            .login-link a {
                color: #0d47a1;
                font-weight: 700;
                text-decoration: none;
            }

        .terms-text {
            text-align: center;
            font-size: 0.7rem;
            color: #94a3b8;
            margin-top: 40px;
        }

        @@media (max-width: 768px) {
            .register-container {
                flex-direction: column;
            }

            .info-panel, .form-panel {
                padding: 40px 30px;
            }

            .bottom-footer {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>

    <div class="register-container">
        <div class="info-panel">
            <div class="brand">Guardian Health</div>
            <h1 class="headline">Hành trình sức khỏe<br><span>Bắt đầu từ đây.</span></h1>
            <p class="sub-headline">Tham gia cùng chúng tôi để trải nghiệm sự kết hợp giữa độ chính xác y khoa và sự chăm sóc tận tâm.</p>

            <div class="badge-secure">
                <div class="badge-icon"><i class="bi bi-shield-check"></i></div>
                <div class="badge-text">
                    <strong>Bảo mật & Riêng tư</strong>
                    <span>Tiêu chuẩn bảo vệ HIPAA</span>
                </div>
            </div>
        </div>

        <div class="form-panel">
            <h2 class="form-title">Tạo tài khoản mới</h2>
            <p class="form-subtitle">Nhập thông tin chi tiết của bạn để đăng ký làm bệnh nhân.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger fw-bold" style="border-radius: 12px; font-size: 0.85rem; padding: 12px; margin-bottom: 20px; color: #842029; background-color: #f8d7da; border: 1px solid #f5c2c7;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                </div>
            }

            <form asp-controller="Auth" asp-action="Register" method="post">
                <label class="input-label">Họ và tên</label>
                <div class="input-group-custom">
                    <i class="bi bi-person"></i>
                    <input type="text" name="fullname" class="form-control-custom" placeholder="Nguyễn Văn A" required>
                </div>

                <label class="input-label">Tên đăng nhập hoặc Email</label>
                <div class="input-group-custom">
                    <i class="bi bi-envelope"></i>
                    <input type="text" name="email" class="form-control-custom" placeholder="vi-du@email.com" required>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <label class="input-label">Mật khẩu</label>
                        <div class="input-group-custom">
                            <i class="bi bi-lock"></i>
                            <input type="password" name="password" class="form-control-custom" placeholder="••••••••" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="input-label">Xác nhận mật khẩu</label>
                        <div class="input-group-custom">
                            <i class="bi bi-arrow-repeat"></i>
                            <input type="password" name="confirmPassword" class="form-control-custom" placeholder="••••••••" required>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-primary-custom">
                    Đăng ký ngay <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <div class="login-link">
                Đã có tài khoản?
                <a asp-controller="Auth" asp-action="Login">Đăng nhập ngay</a>
            </div>

            <p class="terms-text">Bằng việc tạo tài khoản, bạn đồng ý với Điều khoản Dịch vụ và Chính sách Bảo mật của Guardian Health.<br>Dữ liệu y tế của bạn được mã hóa và bảo vệ theo tiêu chuẩn quốc tế.</p>
        </div>
    </div>

    

</body>
</html>