@model HealthGuard.Models.Dto.PatientProfileDto
@{
    ViewData["Title"] = "Hồ sơ Bệnh nhân - HealthGuard";
    Layout = null;

    // Logic tính BMI giữ nguyên, lấy dữ liệu từ Model
    var bmiValue = (Model.Weight > 0 && Model.Height > 0)
                   ? Math.Round(Model.Weight / Math.Pow(Model.Height / 100.0, 2), 1)
                   : 0;

    // Logic xác định trạng thái BMI
    string bmiStatus = "Bình thường";
    if (bmiValue > 0 && bmiValue < 18.5) bmiStatus = "Gầy";
    else if (bmiValue >= 25) bmiStatus = "Thừa cân (Overweight)";
    else if (bmiValue == 0) bmiStatus = "Chưa có dữ liệu";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        /* TOÀN BỘ CSS CỦA ÔNG GIỮ NGUYÊN 100% */
        :root {
            --primary-blue: #0d47a1;
            --bg-color: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --input-bg: #f1f5f9;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            padding-bottom: 50px;
        }


        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 30px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            padding: 0 20px;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: 800;
            margin-bottom: 5px;
        }

        .page-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin: 0;
        }

        .btn-cancel {
            color: var(--primary-blue);
            font-weight: 700;
            text-decoration: none;
            padding: 10px 20px;
            font-size: 0.9rem;
        }

        .btn-save {
            background-color: var(--primary-blue);
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.2s;
        }

            .btn-save:hover {
                background-color: #155eef;
                color: white;
            }

        .container-custom {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .profile-card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.02);
            margin-bottom: 30px;
            position: relative;
            overflow: hidden;
        }

        .border-accent-blue::before {
            content: '';
            position: absolute;
            left: 0;
            top: 30px;
            bottom: 30px;
            width: 4px;
            background-color: #3b82f6;
            border-radius: 0 4px 4px 0;
        }

        .border-accent-orange::before {
            content: '';
            position: absolute;
            left: 0;
            top: 30px;
            bottom: 30px;
            width: 4px;
            background-color: #d97706;
            border-radius: 0 4px 4px 0;
        }

        .card-header-custom {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
            gap: 15px;
        }

        .header-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .icon-blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .icon-orange {
            background: #fffbeb;
            color: #d97706;
        }

        .card-title-custom {
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0;
        }

        .form-label-custom {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            display: block;
        }

        .form-control-custom {
            width: 100%;
            background-color: var(--input-bg);
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.95rem;
            color: var(--text-main);
            font-weight: 500;
            transition: 0.2s;
        }

            .form-control-custom:focus {
                background-color: white;
                border-color: #cbd5e1;
                outline: none;
                box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.05);
            }

        .history-item {
            background: var(--input-bg);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .history-title {
            font-weight: 700;
            margin-bottom: 5px;
            font-size: 0.95rem;
        }

        .history-desc {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin: 0;
        }

        .bio-input-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .bio-input-group .form-control-custom {
                width: 80px;
                text-align: center;
            }

        .bmi-container {
            background: var(--input-bg);
            border-radius: 16px;
            padding: 20px;
            margin-top: 25px;
        }

        .bmi-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .bmi-value {
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--primary-blue);
        }

        .bmi-bar-bg {
            height: 6px;
            background: #cbd5e1;
            border-radius: 3px;
            position: relative;
            overflow: hidden;
            margin-bottom: 8px;
        }

        .bmi-bar-fill {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            background: #334155;
            border-radius: 3px;
        }

        .complete-card {
            background: #f0f4ff;
            border-radius: 16px;
            padding: 25px;
            border: 1px solid #e0e7ff;
        }

        .complete-header {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 15px;
        }

        .progress-custom {
            height: 8px;
            border-radius: 4px;
            background: #e0e7ff;
            margin-bottom: 15px;
        }

        .progress-bar-custom {
            background: var(--primary-blue);
            border-radius: 4px;
            width: 85%;
            height: 100%;
        }
    </style>
</head>
<body>

    <nav style="display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; background: white; border-bottom: 1px solid #e2e8f0; margin-bottom: 30px;">

        <a asp-controller="Home" asp-action="Index" style="font-size: 1.6rem; font-weight: 800; color: #2563eb; text-decoration: none; letter-spacing: -0.5px;">
            HealthGuard
        </a>

        

        <div style="display: flex; align-items: center; gap: 20px;">

            

            <i class="bi bi-bell" style="font-size: 1.2rem; color: #64748b; cursor: pointer;"></i>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="dropdown">
                    <div class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 40px; height: 40px; border-radius: 50%; background-color: #20c997; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; cursor: pointer; user-select: none;">
                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                    </div>

                    <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 10px;">
                        <li class="px-3 py-2 border-bottom mb-1">
                            <p class="mb-0 fw-bold text-dark">@User.Identity.Name</p>
                            <small class="text-muted">Bệnh nhân</small>
                        </li>
                        <li>
                            <a class="dropdown-item py-2" asp-controller="Patient" asp-action="Index">
                                <i class="bi bi-person me-2"></i>Hồ sơ cá nhân
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <div style="width: 40px; height: 40px; border-radius: 50%; background-color: #94a3b8; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">U</div>
            }
        </div>
    </nav>

    <form asp-controller="Patient" asp-action="UpdateProfile" method="post">

        <input type="hidden" asp-for="Id" />

        <div class="page-header">
            <div>
                <h1 class="page-title">Hồ sơ Bệnh nhân</h1>
                <p class="page-subtitle">Quản lý thông tin cá nhân và tiền sử y tế của bạn.</p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn-cancel">HỦY BỎ</a>
                <button type="submit" class="btn-save">LƯU THAY ĐỔI</button>
            </div>
        </div>

        <div class="container-custom">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: 12px;">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                </div>
            }

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="profile-card border-accent-blue">
                        <div class="card-header-custom">
                            <div class="header-icon icon-blue"><i class="bi bi-person"></i></div>
                            <h2 class="card-title-custom">Thông tin cá nhân</h2>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom" asp-for="FullName">HỌ VÀ TÊN</label>
                                <input type="text" asp-for="FullName" class="form-control-custom" placeholder="Nhập họ tên">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom" asp-for="DateOfBirth">NGÀY SINH</label>
                                <input type="date" asp-for="DateOfBirth" class="form-control-custom">
                            </div>
                            <div class="col-12">
                                <label class="form-label-custom" asp-for="Email">ĐỊA CHỈ EMAIL</label>
                                <input type="email" asp-for="Email" class="form-control-custom" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom" asp-for="PhoneNumber">SỐ ĐIỆN THOẠI</label>
                                <input type="tel" asp-for="PhoneNumber" class="form-control-custom">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom" asp-for="EmergencyContact">LIÊN HỆ KHẨN CẤP</label>
                                <input type="tel" asp-for="EmergencyContact" class="form-control-custom">
                            </div>
                        </div>
                    </div>

                    <div class="profile-card border-accent-blue">
                        <div class="card-header-custom">
                            <div class="header-icon icon-blue"><i class="bi bi-clock-history"></i></div>
                            <h2 class="card-title-custom">Tiền sử bệnh lý</h2>
                        </div>

                        <div class="mb-3">
                            <label class="form-label-custom" asp-for="MedicalHistory">MÔ TẢ TIỀN SỬ BỆNH</label>
                            <textarea asp-for="MedicalHistory" class="form-control-custom" rows="4" placeholder="Ví dụ: Cao huyết áp, dị ứng thuốc lá..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="profile-card border-accent-orange">
                        <div class="card-header-custom">
                            <div class="header-icon icon-orange"><i class="bi bi-clipboard2-pulse"></i></div>
                            <h2 class="card-title-custom">Chỉ số sinh tồn</h2>
                        </div>

                        <div class="d-flex gap-5 mb-2">
                            <div>
                                <label class="form-label-custom" asp-for="Height">CHIỀU CAO (CM)</label>
                                <div class="bio-input-group" style="display: flex; flex-wrap: nowrap; align-items: center; gap: 10px;">
    <input type="number" step="0.1" asp-for="Height" class="form-control-custom" style="width: 90px;">
    <span class="bio-unit">cm</span>
</div>
                            </div>
                            <div>
                                <label class="form-label-custom" asp-for="Weight">CÂN NẶNG (KG)</label>
                                <div class="bio-input-group" style="display: flex; flex-wrap: nowrap; align-items: center; gap: 10px;">
                                    <input type="number" step="0.1" asp-for="Weight" class="form-control-custom" style="width: 90px;">
                                    <span class="bio-unit">kg</span>
                                </div>
                            </div>
                        </div>

                        <div class="bmi-container">
                            <div class="bmi-header">
                                <span class="bmi-title">Chỉ số BMI của bạn</span>
                                <span class="bmi-value">@bmiValue</span>
                            </div>
                            <div class="bmi-bar-bg">
                                <div class="bmi-bar-fill" style="width: @(Math.Min(bmiValue * 3, 100))%"></div>
                            </div>
                            <div class="bmi-status">Trạng thái: @bmiStatus</div>
                        </div>
                    </div>

                    <div class="complete-card">
                        <div class="complete-header">
                            <i class="bi bi-shield-check"></i>
                            <span>Mức độ hoàn thiện hồ sơ</span>
                        </div>
                        <div class="progress-custom">
                            <div class="progress-bar-custom" style="width: 85%"></div>
                        </div>
                        <p class="complete-desc">Hồ sơ của bạn đã cơ bản hoàn thiện. Đừng quên cập nhật các chỉ số sinh tồn thường xuyên.</p>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>