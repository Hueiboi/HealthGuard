@{
    ViewData["Title"] = "Lịch sử Chẩn đoán - HealthGuard";
    Layout = null; // Tạm thời vẫn để null cho đến khi ông dùng chung _Layout
}
@model IEnumerable<HealthGuard.Models.Entity.DiagnosticSession>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-blue: #2563eb;
            --bg-color: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-light: #e2e8f0;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            padding-bottom: 60px;
        }

        /* KHU VỰC TIÊU ĐỀ TRANG */
        .page-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px 40px;
        }

        .header-label {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 15px;
            letter-spacing: -1px;
        }

        .page-desc {
            color: var(--text-muted);
            font-size: 1.05rem;
            max-width: 600px;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        /* BỐ CỤC BENTO GRID */
        .history-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .card-wide {
            grid-column: span 2;
        }

        /* THIẾT KẾ THẺ BÀI (CARD) */
        .history-card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.03);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.02);
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .history-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 15px 50px rgba(0,0,0,0.06);
            }

        /* Thẻ đặc biệt: Hình ảnh X-Quang */
        .card-image-bg {
            background: linear-gradient(to top, rgba(15,23,42,0.9), rgba(15,23,42,0.4)), url('https://images.unsplash.com/photo-1530497610245-94d3c16cda28?auto=format&fit=crop&q=80&w=800') center/cover;
            color: white;
            justify-content: flex-end;
        }

            .card-image-bg .page-title, .card-image-bg .text-muted {
                color: white !important;
            }

        .date-pill {
            background-color: #f1f5f9;
            color: var(--text-muted);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            width: fit-content;
            margin-bottom: 20px;
        }

        .card-title {
            font-size: 1.4rem;
            font-weight: 800;
            margin-bottom: 5px;
        }

        .doctor-info {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 25px;
        }

        /* DANH SÁCH CHI TIẾT TRONG CARD */
        .detail-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 15px;
        }

        .detail-icon {
            width: 24px;
            height: 24px;
            background: #f1f5f9;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-right: 12px;
            margin-top: 2px;
        }

        .detail-content strong {
            display: block;
            font-size: 0.9rem;
            color: var(--text-main);
        }

        .detail-content span {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        /* Nút hành động */
        .btn-link-custom {
            margin-top: auto;
            text-align: right;
            color: var(--primary-blue);
            font-weight: 700;
            text-decoration: none;
            font-size: 0.95rem;
        }

        .btn-block-custom {
            margin-top: auto;
            background: #f1f5f9;
            color: var(--text-main);
            border: none;
            width: 100%;
            padding: 12px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.9rem;
            transition: 0.2s;
        }

            .btn-block-custom:hover {
                background: #e2e8f0;
            }

        .prob-badge {
            position: absolute;
            top: 30px;
            right: 30px;
            text-align: center;
        }

            .prob-badge span {
                display: block;
                font-size: 0.65rem;
                color: var(--text-muted);
                text-transform: uppercase;
                font-weight: 700;
            }

            .prob-badge strong {
                font-size: 1.2rem;
                color: #0284c7;
                font-weight: 800;
            }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
        }

        .dot-normal {
            background-color: #2563eb;
        }

        .dot-warning {
            background-color: #dc2626;
        }

        @@media (max-width: 992px) {
            .history-grid {
                grid-template-columns: 1fr;
            }

            .card-wide {
                grid-column: span 1;
            }
        }
    </style>
</head>
<body>

    <nav style="display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; background: white; border-bottom: 1px solid #e2e8f0; margin-bottom: 30px;">
        <a asp-controller="Home" asp-action="Index" style="font-size: 1.6rem; font-weight: 800; color: #2563eb; text-decoration: none; letter-spacing: -0.5px;">
            HealthGuard
        </a>
        <div style="flex: 1; max-width: 400px; margin: 0 20px;">
            <div style="background-color: #f4f6f8; border-radius: 20px; padding: 10px 20px; display: flex; align-items: center; color: #64748b;">
                <i class="bi bi-search me-2"></i>
                <input type="text" placeholder="Tìm kiếm hồ sơ, thuốc..." style="border: none; background: transparent; width: 100%; outline: none; color: #334155; font-size: 0.95rem;">
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
            <a asp-controller="Diagnostic" asp-action="Index" style="background-color: #2563eb; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 10px rgba(37,99,235,0.2);">
                <i class="bi bi-stars"></i> AI Diagnosis Wizard
            </a>
            <i class="bi bi-bell" style="font-size: 1.2rem; color: #64748b; cursor: pointer;"></i>
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="dropdown">
                    <div class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 40px; height: 40px; border-radius: 50%; background-color: #20c997; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; cursor: pointer; user-select: none;">
                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 10px;">
                        <li class="px-3 py-2 border-bottom mb-1"><p class="mb-0 fw-bold text-dark">@User.Identity.Name</p><small class="text-muted">Bệnh nhân</small></li>
                        <li><a class="dropdown-item py-2" asp-controller="Patient" asp-action="Index"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
                        <li><a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            }
            else
            {
                <div style="width: 40px; height: 40px; border-radius: 50%; background-color: #94a3b8; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">U</div>
            }
        </div>
    </nav>

    <main class="page-container">

        <div class="header-label"><i class="bi bi-clock-history"></i> PATIENT RECORDS</div>
        <h1 class="page-title">Diagnosis History</h1>
        <p class="page-desc">Tổng quan toàn diện về các đánh giá y tế trong quá khứ, kết quả hình ảnh và các buổi tư vấn chuyên khoa của bạn.</p>

        <div class="history-grid">

            @{ int index = 0; }
            @if (Model != null && Model.Any())
            {
                foreach (var session in Model)
                {
                    // Lấy ra bệnh có tỉ lệ cao nhất trong lần khám này
                    var topDisease = session.DiagnosisResults.OrderByDescending(r => r.ProbabilityPercentage).FirstOrDefault();
                    if (topDisease == null || topDisease.Disease == null) continue;

                    // Tính toán nhãn rủi ro
                    string probLabel = topDisease.ProbabilityPercentage >= 80 ? "High" : (topDisease.ProbabilityPercentage >= 50 ? "Medium" : "Low");
                    string probColor = probLabel == "High" ? "#dc2626" : (probLabel == "Medium" ? "#d97706" : "#0284c7");

                    // CARD 1: Luôn cho cái mới nhất (index == 0) to ra (card-wide)
                    if (index == 0)
                    {
                        <div class="history-card card-wide" style="border-left: 4px solid #3b82f6;">
                            <div class="date-pill"><i class="bi bi-calendar3"></i> @session.CreatedAt.ToString("MMM dd, yyyy").ToUpper()</div>
                            <div class="prob-badge">
                                <span>Probability</span>
                                <strong style="color: @probColor">@probLabel</strong>
                            </div>
                            
                            <h2 class="card-title">@topDisease.Disease.DiseaseName</h2>
                            <div class="doctor-info">AI Diagnostic System &bull; Logistic Regression Model</div>

                            <div class="detail-item">
                                <div class="detail-icon"><i class="bi bi-activity"></i></div>
                                <div class="detail-content">
                                    <strong>Primary Finding</strong>
                                    <span>Độ tin cậy của thuật toán đạt @topDisease.ProbabilityPercentage%.</span>
                                </div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-icon"><i class="bi bi-clipboard2-pulse"></i></div>
                                <div class="detail-content">
                                    <strong>Action Required</strong>
                                    <span>@topDisease.Disease.Description</span>
                                </div>
                            </div>

                            <a href="#" class="btn-link-custom">View Full Report <i class="bi bi-arrow-right"></i></a>
                        </div>
                    }
                    else
                    {
                        // CÁC CARD CÒN LẠI: Kích thước nhỏ
                        <div class="history-card">
                            <div class="date-pill"><i class="bi bi-calendar3"></i> @session.CreatedAt.ToString("MMM dd, yyyy").ToUpper()</div>
                            <h2 class="card-title" style="font-size: 1.2rem;">@topDisease.Disease.DiseaseName</h2>
                            <div class="doctor-info">HealthGuard AI</div>

                            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 12px;">
                                <span style="color: var(--text-muted); font-size: 0.95rem;">Algorithm Match</span>
                                <strong style="color: @probColor">@topDisease.ProbabilityPercentage%</strong>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 25px;">
                                <span style="color: var(--text-muted); font-size: 0.95rem;">Risk Level</span>
                                <strong><span class="status-dot" style="background-color: @probColor;"></span>@probLabel</strong>
                            </div>

                            <button class="btn-block-custom">Details <i class="bi bi-chevron-right" style="font-size: 0.8rem;"></i></button>
                        </div>
                    }
                    index++;
                }
            }
            else
            {
                <div style="grid-column: span 3; text-align: center; padding: 50px; color: #64748b;">
                    <i class="bi bi-folder-x" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <p class="mt-3">Bạn chưa có lịch sử chẩn đoán nào.</p>
                </div>
            }

            <div class="history-card card-image-bg">
                <div style="font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 5px;"><i class="bi bi-layers"></i> IMAGING ARCHIVE</div>
                <h2 class="card-title" style="color: white; font-size: 1.6rem;">Radiology Reports</h2>
                <p style="color: #cbd5e1; font-size: 0.95rem; margin-bottom: 20px;">Access all historical X-Rays, MRIs, and CT Scans.</p>
                <a href="#" style="color: white; font-weight: 700; text-decoration: none;">Browse Archive <i class="bi bi-arrow-right"></i></a>
            </div>

        </div>

        <div style="text-align: center; margin-top: 40px;">
            <button style="background: #f1f5f9; color: var(--text-main); border: none; padding: 12px 30px; border-radius: 30px; font-weight: 700; transition: 0.2s;"><i class="bi bi-arrow-clockwise me-2"></i> Load Older Records</button>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>