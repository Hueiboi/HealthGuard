@{
    ViewData["Title"] = "Lựa chọn triệu chứng";
    Layout = null; // Tắt Layout mặc định để dùng Header xịn
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - HealthGuard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
            margin: 0;
            padding-bottom: 50px;
        }

        /* --- CSS GIỮ NGUYÊN 100% TỪ FILE CŨ CỦA ÔNG --- */
        .wizard-container {
            max-width: 800px;
            margin: 40px auto;
        }

        .wizard-subtitle {
            color: #2c6fb0;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .wizard-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .wizard-desc {
            color: #555;
            font-size: 0.95rem;
            margin-bottom: 30px;
            line-height: 1.5;
        }

        .progress-track {
            height: 6px;
            background-color: #e5e9f2;
            border-radius: 10px;
            margin-bottom: 30px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background-color: #346cb0;
            width: 25%;
            border-radius: 10px;
        }

        .symptom-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.05);
            margin-bottom: 30px;
        }

        .search-box {
            background-color: #f4f6f8;
            border-radius: 12px;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            margin-bottom: 30px;
        }

            .search-box input {
                border: none;
                background: transparent;
                width: 100%;
                outline: none;
                margin-left: 10px;
            }

        .symptoms-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
        }

        .symptom-chip {
            background-color: #f4f6f8;
            border: 2px solid transparent;
            border-radius: 16px;
            padding: 15px;
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: 0.2s;
            font-weight: 500;
        }

            .symptom-chip.selected {
                background-color: #e2eafc;
                border-color: #346cb0;
                color: #1a4d8c;
            }

        .icon-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            font-size: 1.2rem;
        }

        .symptom-chip.selected .icon-circle {
            background-color: #346cb0;
            color: white;
        }

        .action-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-cancel {
            background: none;
            border: none;
            color: #346cb0;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

            .btn-cancel:hover {
                color: #0d47a1;
            }

        .btn-continue {
            background-color: #0d47a1;
            color: white;
            border: none;
            border-radius: 30px;
            padding: 12px 24px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            transition: 0.2s;
        }

            .btn-continue:hover {
                background-color: #1a4d8c;
            }

            .btn-continue i {
                margin-left: 8px;
            }
    </style>
</head>
<body>

    <nav style="display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; background: white; border-bottom: 1px solid #e2e8f0; margin-bottom: 30px;">
        <a asp-controller="Home" asp-action="Index" style="font-size: 1.6rem; font-weight: 800; color: #2563eb; text-decoration: none; letter-spacing: -0.5px;">
            HealthGuard
        </a>

        <div style="flex: 1; max-width: 400px; margin: 0 20px;">
            <div style="background-color: #f4f6f8; border-radius: 20px; padding: 10px 20px; display: flex; align-items: center; color: #64748b;">
                <i class="bi bi-search me-2"></i>
                <input type="text" placeholder="Tìm kiếm hồ sơ, thuốc..." style="border: none; background: transparent; width: 100%; outline: none; color: #334155; font-size: 0.95rem;">
            </div>
        </div>

        <div style="display: flex; align-items: center; gap: 20px;">
            <a asp-controller="Diagnostic" asp-action="Index" style="background-color: #2563eb; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 10px rgba(37,99,235,0.2);">
                <i class="bi bi-stars"></i> AI Diagnosis Wizard
            </a>

            <i class="bi bi-bell" style="font-size: 1.2rem; color: #64748b; cursor: pointer;"></i>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="dropdown">
                    <div class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 40px; height: 40px; border-radius: 50%; background-color: #20c997; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; cursor: pointer; user-select: none;">
                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 10px;">
                        <li class="px-3 py-2 border-bottom mb-1">
                            <p class="mb-0 fw-bold text-dark">@User.Identity.Name</p>
                            <small class="text-muted">Bệnh nhân</small>
                        </li>
                        <li><a class="dropdown-item py-2" asp-controller="Patient" asp-action="Index"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
                        <li><a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary btn-sm fw-bold" style="border-radius: 20px; padding: 6px 20px;">Đăng nhập</a>
            }
        </div>
    </nav>

    <div class="wizard-container">
        <div class="wizard-subtitle">CÔNG CỤ CHẨN ĐOÁN &bull; BƯỚC 1/3</div>
        <h1 class="wizard-title">Lựa chọn triệu chứng</h1>
        <p class="wizard-desc">Để giúp chúng tôi hiểu rõ hơn về tình trạng của bạn, vui lòng chọn tất cả các triệu chứng mà bạn đang gặp phải.</p>

        <div class="progress-track"><div class="progress-fill"></div></div>

        <div class="symptom-card">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Tìm kiếm triệu chứng...">
            </div>
            <div class="symptoms-grid" id="symptomGrid">
                <div class="text-primary"><i class="spinner-border spinner-border-sm"></i> Đang tải dữ liệu triệu chứng...</div>
            </div>
        </div>

        <div class="action-footer">
            <a asp-controller="Home" asp-action="Index" class="btn-cancel">
                <i class="bi bi-arrow-left me-1"></i> Hủy bỏ
            </a>

            <button class="btn-continue" onclick="submitSymptoms()">
                Tiếp tục nhập chi tiết <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // LOGIC JAVASCRIPT GIỮ NGUYÊN 100%
        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const response = await fetch('/api/patient/diagnose/symptoms');
                const data = await response.json();

                const grid = document.getElementById('symptomGrid');
                grid.innerHTML = "";

                data.forEach(s => {
                    const chip = document.createElement('div');
                    chip.className = 'symptom-chip';
                    chip.setAttribute('data-id', s.id);
                    chip.innerHTML = `<div class="icon-circle"><i class="bi bi-activity"></i></div><span>${s.symptomName}</span>`;
                    chip.onclick = function() { this.classList.toggle('selected'); };
                    grid.appendChild(chip);
                });
            } catch (err) {
                console.error("Lỗi lấy dữ liệu:", err);
                document.getElementById('symptomGrid').innerHTML = "<div class='text-danger'>Không thể tải dữ liệu triệu chứng.</div>";
            }
        });

        function submitSymptoms() {
            const selected = document.querySelectorAll('.symptom-chip.selected');
            if(selected.length === 0) {
                alert("Vui lòng chọn ít nhất 1 triệu chứng để tiếp tục!");
                return;
            }

            const selectedData = Array.from(selected).map(c => {
                return { id: c.getAttribute('data-id'), name: c.querySelector('span').innerText };
            });

            sessionStorage.setItem('healthGuard_Symptoms', JSON.stringify(selectedData));

            window.location.href = '@Url.Action("Details", "Diagnostic")';
        }
    </script>
</body>
</html>