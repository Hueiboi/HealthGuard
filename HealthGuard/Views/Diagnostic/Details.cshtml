@{
    ViewData["Title"] = "Symptom Details";
}

@section Styles {
    <style>
        .wizard-container {
            max-width: 800px;
            margin: 40px auto;
        }

        .stepper {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin-bottom: 50px;
        }

            .stepper::before {
                content: '';
                position: absolute;
                top: 15px;
                left: 0;
                right: 0;
                height: 3px;
                background: #e0e0e0;
                z-index: 1;
            }

        .stepper-progress {
            position: absolute;
            top: 15px;
            left: 0;
            height: 3px;
            background: #0d47a1;
            z-index: 2;
            width: 50%;
            transition: 0.3s;
        }

        .step {
            position: relative;
            z-index: 3;
            text-align: center;
            background: #f4f6f8;
            padding: 0 10px;
        }

        .step-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #e0e0e0;
            color: #666;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            margin: 0 auto 8px auto;
        }

        .step.completed .step-circle {
            background: #0d47a1;
            color: white;
        }

        .step.active .step-circle {
            background: #0d47a1;
            color: white;
        }

        .step-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #888;
            text-transform: uppercase;
        }

        .step.active .step-label, .step.completed .step-label {
            color: #0d47a1;
        }

        .wizard-title {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: #111;
        }

        .wizard-desc {
            color: #666;
            font-size: 1rem;
            margin-bottom: 40px;
        }

        .detail-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            margin-bottom: 25px;
        }

        .card-header-flex {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
        }

        .icon-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e2eafc;
            color: #0d47a1;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 1.2rem;
        }

        .symptom-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: #222;
            margin: 0;
        }

        .input-group-custom {
            display: flex;
            gap: 30px;
        }

        .input-col {
            flex: 1;
        }

        .input-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #888;
            text-transform: uppercase;
            margin-bottom: 12px;
            display: block;
            letter-spacing: 0.5px;
        }

        .intensity-group {
            display: flex;
            gap: 10px;
            background: white;
            border-radius: 30px;
        }

        .intensity-btn {
            flex: 1;
            background: #f4f6f8;
            border: none;
            padding: 10px 0;
            border-radius: 20px;
            font-weight: 600;
            color: #555;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.9rem;
        }

            .intensity-btn.active-mild {
                background: #f1c40f;
                color: white;
            }

            .intensity-btn.active-moderate {
                background: #0d47a1;
                color: white;
            }

            .intensity-btn.active-severe {
                background: #c0392b;
                color: white;
            }

        .duration-input {
            width: 100%;
            background: #f4f6f8;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            font-weight: 600;
            color: #333;
            outline: none;
            font-size: 0.9rem;
        }

        .action-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 40px;
        }

        .btn-back {
            color: #0d47a1;
            font-weight: 600;
            background: none;
            border: none;
            cursor: pointer;
            text-decoration: none;
        }

        .btn-continue {
            background-color: #0d47a1;
            color: white;
            border: none;
            border-radius: 30px;
            padding: 12px 24px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
        }

            .btn-continue i {
                margin-left: 10px;
            }
    </style>
}

<div class="wizard-container">
    <div class="stepper">
        <div class="stepper-progress"></div>
        <div class="step completed"><div class="step-circle"><i class="bi bi-check-lg"></i></div><div class="step-label">Symptoms</div></div>
        <div class="step active"><div class="step-circle">2</div><div class="step-label">Details</div></div>
        <div class="step"><div class="step-circle">3</div><div class="step-label">Review</div></div>
    </div>

    <h1 class="wizard-title">Symptom Details</h1>
    <p class="wizard-desc">Help us understand the intensity and duration of your reported symptoms.</p>

    <div id="dynamicCardsContainer"></div>

    <div class="action-footer">
        <a href="/Diagnostic/Index" class="btn-back">Back to Symptoms</a>
        <button class="btn-continue" onclick="submitDetails()">Continue to Review <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

@section Scripts {
    <script>
        let symptomDetails = [];

        document.addEventListener("DOMContentLoaded", () => {
            const savedData = sessionStorage.getItem('healthGuard_Symptoms');
            if (!savedData) { window.location.href = '/Diagnostic/Index'; return; }

            const symptoms = JSON.parse(savedData);
            const container = document.getElementById('dynamicCardsContainer');

            symptoms.forEach(s => {
                symptomDetails.push({ id: s.id, name: s.name, intensity: 'Moderate', duration: 1 });
                const cardHtml = `
                    <div class="detail-card">
                        <div class="card-header-flex">
                            <div class="icon-circle"><i class="bi bi-activity"></i></div><h3 class="symptom-name">${s.name}</h3>
                        </div>
                        <div class="input-group-custom">
                            <div class="input-col">
                                <span class="input-label">Intensity</span>
                                <div class="intensity-group">
                                    <button class="intensity-btn" onclick="setIntensity('${s.id}', 'Mild', this)">Mild</button>
                                    <button class="intensity-btn active-moderate" onclick="setIntensity('${s.id}', 'Moderate', this)">Moderate</button>
                                    <button class="intensity-btn" onclick="setIntensity('${s.id}', 'Severe', this)">Severe</button>
                                </div>
                            </div>
                            <div class="input-col">
                                <span class="input-label">Duration (Days)</span>
                                <input type="number" class="duration-input" min="1" max="365" value="1" onchange="setDuration('${s.id}', this.value)">
                            </div>
                        </div>
                    </div>`;
                container.innerHTML += cardHtml;
            });
        });

        function setIntensity(id, level, btnElement) {
            const item = symptomDetails.find(x => x.id === id);
            if(item) item.intensity = level;
            const group = btnElement.parentElement;
            group.querySelectorAll('.intensity-btn').forEach(b => b.classList.remove('active-mild', 'active-moderate', 'active-severe'));
            btnElement.classList.add(`active-${level.toLowerCase()}`);
        }

        function setDuration(id, days) {
            const item = symptomDetails.find(x => x.id === id);
            if(item) item.duration = parseInt(days) || 1;
        }

        function submitDetails() {
            sessionStorage.setItem('healthGuard_SymptomDetails', JSON.stringify(symptomDetails));
            window.location.href = '/Diagnostic/Review';
        }
    </script>
}