<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - HealthGuard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        /* CSS của cái Navbar dùng chung */
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f4f6f8;
            margin: 0;
        }

        .portal-header {
            background: white;
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #e0e4e8;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .portal-brand {
            color: #0d47a1;
            font-weight: 700;
            font-size: 1.2rem;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

            .portal-brand i {
                margin-right: 10px;
                font-size: 1.1rem;
            }

        .header-icons i {
            margin-left: 20px;
            font-size: 1.2rem;
            color: #666;
            cursor: pointer;
        }

        .header-icons .bi-person-circle {
            color: #f39c12;
            font-size: 1.4rem;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <header class="portal-header">
        <a href="/Home/Index" class="portal-brand">
            <i class="bi bi-arrow-left"></i> HealthGuard
        </a>
        <div class="header-icons">
            <i class="bi bi-bell"></i>
            <i class="bi bi-gear"></i>
            <i class="bi bi-person-circle"></i>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>